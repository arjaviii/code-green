{
  "name": "code-green",
  "displayName": "Code-Green",
  "description": "Sustainable Computing Audit Tool. Identify and fix energy-inefficient code patterns.",
  "version": "0.1.0",
  "publisher": "antigravity",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "code-green.scan",
        "title": "Code-Green: Scan Current File",
        "icon": "$(zap)"
      },
      {
        "command": "code-green.openDashboard",
        "title": "Code-Green: Open Sustainability Dashboard",
        "icon": "$(dashboard)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "code-green.scan",
          "group": "navigation",
          "when": "resourceLangId == java || resourceLangId == python || resourceLangId == cpp"
        }
      ]
    },
    "colors": [
      {
        "id": "codeGreen.vampireHighlight",
        "description": "Highlight color for energy vampires",
        "defaults": {
          "dark": "#ff000044",
          "light": "#ff000044"
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "@types/node": "^16.11.7",
    "typescript": "^4.9.4"
  }
}
